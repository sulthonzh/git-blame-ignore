{
  "name": "git-blame-ignore",
  "version": "1.1.0",
  "description": "CLI that auto-detects bulk-change commits and manages .git-blame-ignore-revs file",
  "main": "dist/index.js",
  "bin": {
    "git-blame-ignore": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm run lint && npm run build && npm test"
  },
  "keywords": [
    "git",
    "blame",
    "prettier",
    "eslint",
    "format",
    "development",
    "cli",
    "utility"
  ],
  "author": "Sulthonzh",
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.0.0",
    "inquirer": "^9.2.0",
    "simple-git": "^3.20.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.45.0",
    "jest": "^29.6.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./scanner": "./dist/scanner.js",
    "./file-manager": "./dist/file-manager.js"
  }
}